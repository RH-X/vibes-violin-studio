---
import Layout from '../layouts/Layout.astro';
import CTABand from '../components/CTABand.astro';
---

<Layout
  title="Insights — Vibrations Violin Studio | Denver, CO"
  description="Tips, practice ideas, and insights for violin students and parents from Rae at Vibrations Violin Studio in Denver, Colorado."
  noindex={true}
>
  <section
    class="section-pad"
    style="background: linear-gradient(135deg, #b4e7d0 0%, #ddd6fe 100%);"
    aria-labelledby="insights-heading"
  >
    <div class="container-narrow max-w-3xl">
      <p class="text-xs font-semibold uppercase tracking-widest text-purplePrimary mb-3">Insights</p>
      <h1 id="insights-heading" class="text-4xl sm:text-5xl font-light text-ink leading-tight">
        Violin Tips &amp; Ideas
      </h1>
      <p class="mt-4 text-lg text-ink/70 font-light leading-relaxed">
        Practice strategies, parent guides, and musical musings from the studio.
      </p>
    </div>
  </section>

  <section class="bg-white section-pad">
    <div class="container-narrow max-w-3xl">
      <ul class="space-y-6" role="list">

        <!-- Post: What Most Beginners Get Wrong About Learning Violin -->
        <li class="bg-lavender-50 border border-lavender-200 rounded-card p-6 sm:p-8">
          <div class="flex flex-wrap items-center gap-3 text-xs text-ink/50 font-light mb-3">
            <span>May 15, 2026</span>
            <span aria-hidden="true">·</span>
            <span>6 min read</span>
          </div>
          <h2 class="text-xl sm:text-2xl font-light text-ink leading-snug">
            <a
              href="/insights/beginner-violin-learning-myths-denver"
              class="hover:text-purplePrimary transition-colors duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-purplePrimary rounded"
            >
              What Most Beginners Get Wrong About Learning Violin
            </a>
          </h2>
          <p class="mt-3 text-sm text-ink/60 font-light leading-relaxed">
            Many beginners assume violin progress should feel smooth, fast, or natural. But real growth often starts with learning how to struggle slowly, kindly, and consistently.
          </p>
          <a
            href="/insights/beginner-violin-learning-myths-denver"
            class="inline-block mt-5 text-sm font-medium text-purplePrimary hover:text-purple-800 transition-colors duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-purplePrimary rounded"
            aria-label="Read: What Most Beginners Get Wrong About Learning Violin"
          >
            Read article →
          </a>
        </li>

      </ul>
    </div>
  </section>

  <CTABand />
</Layout>
