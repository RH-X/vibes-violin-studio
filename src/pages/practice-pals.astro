---
import Layout from '../layouts/Layout.astro';
import CTABand from '../components/CTABand.astro';
---

<Layout
  title="Practice Pals — Vibrations Violin Studio | Denver, CO"
  description="Practice Pals helps violin students stay motivated and engaged between lessons with curated videos, guided practice tools, and encouragement."
>
  <section
    class="section-pad"
    style="background: linear-gradient(135deg, #d8f3e7 0%, #ddd6fe 100%);"
    aria-labelledby="practice-pals-heading"
  >
    <div class="container-narrow max-w-3xl">
      <p class="text-xs font-semibold uppercase tracking-widest text-mint-500 mb-3">Feature</p>
      <h1 id="practice-pals-heading" class="text-4xl sm:text-5xl font-light text-ink leading-tight">
        Practice Pals
      </h1>
      <p class="mt-4 text-lg text-ink/70 font-light leading-relaxed">
        Make violin practice fun and positive — every single day.
      </p>
    </div>
  </section>

  <section class="bg-white section-pad">
    <div class="container-narrow max-w-3xl">
      <div class="prose prose-lg max-w-none text-ink/70 font-light leading-relaxed space-y-5">
        <p>
          Practice Pals is a resource built to help students stay motivated and engaged between lessons. With curated videos, guided practice tools, and built-in encouragement, it turns at-home practice into something students actually look forward to.
        </p>
        <p>
          Designed by Rae to complement the in-lesson experience and support families in making practice a positive, consistent part of the day — without the battles.
        </p>
      </div>

      <div class="mt-12 bg-lavender-50 border border-lavender-200 rounded-card p-8 text-center">
        <p class="text-ink/50 font-light">Full Practice Pals details coming soon.</p>
        <p class="text-ink/40 text-sm mt-2">This page is in progress — check back shortly.</p>
      </div>
    </div>
  </section>

  <CTABand />
</Layout>
