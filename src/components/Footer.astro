---
const year = new Date().getFullYear();
---

<footer class="bg-white py-10 px-4">
  <div class="max-w-6xl mx-auto">
    <!-- Card shell -->
    <div class="bg-lavender-50 border border-lavender-200 rounded-card shadow-card px-6 sm:px-10 py-8">

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">

        <!-- Studio info -->
        <div>
          <div class="flex items-center gap-2.5 mb-3">
            <span class="flex-shrink-0 w-8 h-8 rounded-full bg-gradient-to-br from-mint-300 to-lavender-300 flex items-center justify-center">
              <svg width="16" height="16" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M10 3 C10 3 7 6 7 10 C7 14 9 16 10 17 C11 16 13 14 13 10 C13 6 10 3 10 3Z" fill="white" opacity="0.9"/>
                <ellipse cx="10" cy="10.5" rx="2" ry="2" fill="white" opacity="0.7"/>
              </svg>
            </span>
            <span class="font-medium text-ink text-sm">Vibrations Violin Studio</span>
          </div>
          <p class="text-ink/60 text-sm leading-relaxed">
            Private violin lessons in Denver, Colorado.
          </p>
          <p class="mt-3 text-ink/50 text-xs leading-relaxed">
            Serving Wash Park, Capitol Hill, Cherry Creek,<br />
            Highlands, and surrounding Denver neighborhoods.
          </p>
        </div>

        <!-- Links -->
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-ink/40 mb-3">Navigation</p>
          <nav aria-label="Footer navigation">
            <ul class="flex flex-col gap-2">
              {[
                { label: 'About', href: '/about' },
                { label: 'Practice Pals', href: '/practice-pals' },
                { label: 'Contact', href: '/contact' },
              ].map(({ label, href }) => (
                <li>
                  <a
                    href={href}
                    class="text-sm text-ink/60 hover:text-purplePrimary transition-colors duration-150"
                  >
                    {label}
                  </a>
                </li>
              ))}
              <li>
                <a
                  href="https://www.google.com/maps/search/Vibrations+Violin+Studio+Denver"
                  class="text-sm text-ink/60 hover:text-purplePrimary transition-colors duration-150"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  Read Reviews on Google ↗
                </a>
              </li>
            </ul>
          </nav>
        </div>

        <!-- Contact / GEO -->
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-ink/40 mb-3">Contact</p>
          <address class="not-italic flex flex-col gap-2">
            <span class="flex items-start gap-2 text-sm text-ink/60">
              <svg class="mt-0.5 flex-shrink-0 text-mint-500" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              Denver, CO
            </span>
            <a
              href="tel:+17205550100"
              class="flex items-center gap-2 text-sm text-ink/60 hover:text-purplePrimary transition-colors"
              aria-label="Call Vibrations Violin Studio"
            >
              <svg class="flex-shrink-0 text-mint-500" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              <!-- Replace with real number -->
              (720) 555-0100
            </a>
            <a
              href="mailto:rae@vibrationsvioilinstudio.com"
              class="flex items-center gap-2 text-sm text-ink/60 hover:text-purplePrimary transition-colors"
              aria-label="Email Vibrations Violin Studio"
            >
              <svg class="flex-shrink-0 text-mint-500" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              <!-- Replace with real email -->
              rae@vibrationsviolin.com
            </a>
          </address>
        </div>

      </div>

      <!-- Bottom bar -->
      <div class="mt-8 pt-6 border-t border-lavender-200 flex flex-col sm:flex-row items-center justify-between gap-2">
        <p class="text-xs text-ink/40">
          &copy; {year} Vibrations Violin Studio &mdash; Denver, CO
        </p>
        <p class="text-xs text-ink/30">
          Private violin lessons for all ages &amp; levels.
        </p>
      </div>

    </div>
  </div>
</footer>
