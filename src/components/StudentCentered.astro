---
const cards = [
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>`,
    title: 'Suzuki-Informed Pedagogy',
    body: 'Drawing on the Suzuki approach, lessons nurture listening, memory, and a lifelong love of music.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>`,
    title: 'Lessons Tailored to Each Student',
    body: 'Every student is different. Rae crafts a learning path that fits your child\'s pace, interests, and goals.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
    title: 'Confidence Through Joyful Learning',
    body: 'A warm, encouraging studio environment helps students build real confidence alongside real skills.',
  },
];
---

<section
  id="approach"
  class="bg-white section-pad"
  aria-labelledby="approach-heading"
>
  <div class="container-narrow">
    <div class="max-w-2xl mb-12">
      <h2
        id="approach-heading"
        class="text-3xl sm:text-4xl font-light text-ink leading-tight"
      >
        A Supportive, Student-Centered Approach to Violin
      </h2>
      <p class="mt-4 text-base text-ink/60 font-light leading-relaxed">
        Every lesson is designed around the whole student — not just technique. Rae creates a safe, encouraging space where learners of all ages can grow musically and personally.
      </p>
    </div>

    <ul class="grid grid-cols-1 sm:grid-cols-3 gap-6" role="list">
      {cards.map(({ icon, title, body }) => (
        <li class="bg-lavender-50 border border-lavender-200 rounded-card p-6 flex flex-col gap-4">
          <!-- Circle icon -->
          <span class="flex-shrink-0 w-10 h-10 rounded-full bg-lavender-200 flex items-center justify-center">
            <svg
              class="text-purplePrimary"
              width="18"
              height="18"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <Fragment set:html={icon} />
            </svg>
          </span>
          <div>
            <h3 class="font-medium text-ink text-base leading-snug">{title}</h3>
            <p class="mt-2 text-sm text-ink/60 font-light leading-relaxed">{body}</p>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>
