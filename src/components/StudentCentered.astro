---
const cards = [
  {
    emoji: '/images/icons/brain.png',
    bg: '/images/icons/brain-ellipse-background.png',
    title: 'Suzuki-Informed Pedagogy',
    body: 'Lessons incorporate Suzuki principles of listening, repetition, and gradual skill development to build strong musical foundations.',
  },
  {
    emoji: '/images/icons/violin.png',
    bg: '/images/icons/violin-Ellipse-background.png',
    title: 'Lessons Tailored to Each Student',
    body: 'Instruction adapts to each student\'s learning style, visual, auditory, or kinesthetic, so every learner can grow in the way that works best for them.',
  },
  {
    emoji: '/images/icons/star.png',
    bg: '/images/icons/star-Ellipse-background.png',
    title: 'Confidence Through Joyful Learning',
    body: 'A supportive environment helps students develop confidence, resilience, and a lifelong love of music.',
  },
];
---

<section
  id="approach"
  class="bg-white section-pad"
  aria-labelledby="approach-heading"
>
  <div class="container-narrow">
    <div class="max-w-2xl mb-12">
      <h2
        id="approach-heading"
        class="text-3xl sm:text-4xl font-light text-ink leading-tight"
      >
        A Supportive, Student-Centered Approach to Violin
      </h2>
      <p class="mt-4 text-base text-ink/60 font-light leading-relaxed">
        Lessons are designed to meet each student where they are. Drawing on Suzuki teacher training and years of teaching experience, instruction focuses on building musical foundations, confidence, and a lasting connection to music.
      </p>
    </div>

    <ul class="grid grid-cols-1 sm:grid-cols-3 gap-6" role="list">
      {cards.map(({ emoji, bg, title, body }) => (
        <li class="bg-lavender-50 border border-lavender-200 rounded-lg p-6 flex flex-col items-center gap-4">
          <!-- Emoji on ellipse background -->
          <div class="relative w-20 h-20">
            <img src={bg} alt="" class="w-full h-full object-contain" aria-hidden="true" />
            <img src={emoji} alt="" class="absolute inset-0 m-auto w-12 h-12 object-contain" aria-hidden="true" />
          </div>
          <div class="text-center">
            <h3 class="font-medium text-ink text-base leading-snug">{title}</h3>
            <p class="mt-2 text-sm text-ink/60 font-light leading-relaxed">{body}</p>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>
