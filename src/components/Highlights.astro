---
const highlights = [
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>`,
    label: '20+ Years\nTeaching Violin',
    blob: '/images/backgrounds/Vector1green.png',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
    label: 'Suzuki-Trained\nInstructor',
    blob: '/images/backgrounds/Vector2orange.png',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>`,
    label: 'Supportive,\nConfidence-Building\nLessons',
    blob: '/images/backgrounds/Vector3purple.png',
  },
];
---

<section class="bg-white section-pad" aria-label="Studio highlights">
  <div class="container-narrow">
    <ul class="grid grid-cols-1 sm:grid-cols-3 gap-8" role="list">
      {highlights.map(({ icon, label, blob }) => (
        <li class="flex flex-col items-center text-center">
          <!-- Blob as card: icon + text layered inside -->
          <div class="relative w-56 h-56 flex flex-col items-center justify-center gap-2 pt-2">
            <img
              src={blob}
              alt=""
              aria-hidden="true"
              class="absolute inset-0 w-full h-full object-contain"
              loading="lazy"
            />
            <span class="relative z-10 flex-shrink-0 w-10 h-10 rounded-full bg-ink/80 flex items-center justify-center">
              <svg
                class="text-white"
                width="20"
                height="20"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <Fragment set:html={icon} />
              </svg>
            </span>
            <p class="relative z-10 text-ink text-sm font-medium leading-snug whitespace-pre-line">{label}</p>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>
