---
---

<section
  class="relative overflow-hidden section-pad"
  style="background: linear-gradient(135deg, #fbd0b0 0%, #b4e7d0 100%);"
  aria-labelledby="cta-heading"
>
  <!-- Decorative softeners -->
  <div class="pointer-events-none absolute -top-16 -right-16 w-72 h-72 rounded-full bg-peach-200 opacity-40 blur-3xl" aria-hidden="true"></div>
  <div class="pointer-events-none absolute -bottom-16 -left-16 w-64 h-64 rounded-full bg-mint-200 opacity-40 blur-3xl" aria-hidden="true"></div>

  <div class="relative container-narrow text-center max-w-2xl mx-auto">
    <h2
      id="cta-heading"
      class="text-3xl sm:text-4xl font-light text-ink leading-tight"
    >
      Ready to Start Violin Lessons?
    </h2>
    <p class="mt-5 text-base sm:text-lg text-ink/70 font-light leading-relaxed">
      Book a friendly 15-minute intro chat with Rae to explore whether violin lessons might be something you'd like to try.
    </p>
    <a href="/contact" class="btn-primary inline-block mt-8 text-base px-8 py-3.5">
      Get Started
    </a>
  </div>
</section>
