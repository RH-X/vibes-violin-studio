---
---

<section
  class="section-pad"
  style="background-color: #ede9fe;"
  aria-labelledby="testimonials-heading"
>
  <div class="container-narrow">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

      <!-- Left: quote block -->
      <div>
        <!-- Star rating -->
        <div class="flex items-center justify-center gap-1 mb-4" aria-label="5 out of 5 stars">
          {Array.from({ length: 5 }).map(() => (
            <svg class="text-yellow-400" width="20" height="20" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          ))}
        </div>

        <!-- Quote -->
        <blockquote class="text-ink/80 text-lg sm:text-xl font-light leading-relaxed">
          <p>
            "My kids, aged 6 and 3, had a really wonderful experience with violin here. I was impressed with how the lessons were tailored to their abilities, their interests, and also whatever energy and behavior they were bringing with them that day ;) it's also a very approachable entry point to violin, in general. Other Suzuki programs felt a little overwhelming to me in terms of the commitment, especially when I wasn't sure how the kids would take to it. This experience felt relaxed and yet meaningful and supportive of this early learning and exposure."
          </p>
        </blockquote>
        <cite class="mt-5 block text-sm font-medium text-ink/60 not-italic">
          — Aya Takemoto
        </cite>

      </div>

      <!-- Right: photo + link -->
      <div class="flex flex-col items-center lg:items-start lg:max-w-sm gap-4">
        <div class="w-full max-w-sm rounded-lg overflow-hidden shadow-card">
          <img
            src="/images/testimonials/testimonial-student.png"
            alt="A young violin student proudly holding up a hand-drawn picture of a violin"
            class="w-full h-auto object-cover"
            loading="lazy"
          />
        </div>

        <a
          href="https://www.google.com/maps/search/Vibrations+Violin+Studio+Denver"
          class="lg:self-end text-sm font-medium text-purplePrimary hover:text-purple-800 underline underline-offset-4 transition-colors"
          target="_blank"
          rel="noopener noreferrer"
        >
          Read More Reviews on Google &rarr;
        </a>
      </div>

    </div>

    <!-- Carousel dots (visual only) -->
    <div class="mt-10 flex justify-center gap-2" aria-hidden="true">
      <span class="w-3 h-3 rounded-full bg-purplePrimary"></span>
      <span class="w-3 h-3 rounded-full bg-lavender-300"></span>
    </div>
  </div>
</section>
