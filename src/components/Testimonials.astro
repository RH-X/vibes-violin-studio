---
---

<section
  class="section-pad"
  style="background-color: #ede9fe;"
  aria-labelledby="testimonials-heading"
>
  <div class="container-narrow">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

      <!-- Left: quote block -->
      <div>
        <!-- Star rating -->
        <div class="flex items-center gap-1 mb-4" aria-label="5 out of 5 stars">
          {Array.from({ length: 5 }).map(() => (
            <svg class="text-yellow-400" width="20" height="20" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          ))}
        </div>

        <!-- Quote -->
        <blockquote class="text-ink/80 text-lg sm:text-xl font-light leading-relaxed">
          <p>
            "Rae has been an incredible teacher for my daughter. She's patient, encouraging, and really knows how to make lessons feel joyful — not stressful. We've seen such a boost in her confidence both on and off the violin."
          </p>
        </blockquote>
        <cite class="mt-5 block text-sm font-medium text-ink/60 not-italic">
          — Parent of a violin student, Denver CO
        </cite>

        <!-- Carousel dots (visual only) -->
        <div class="mt-8 flex items-center gap-2" aria-hidden="true">
          <span class="w-3 h-3 rounded-full bg-purplePrimary"></span>
          <span class="w-3 h-3 rounded-full bg-lavender-300"></span>
        </div>
      </div>

      <!-- Right: photo + link -->
      <div class="flex flex-col items-center lg:items-end gap-4">
        <!-- Testimonial photo placeholder -->
        <!-- REPLACE: update src when real photo is available -->
        <!-- Real photo goes in: public/images/testimonials/testimonial-student.jpg -->
        <div
          class="w-full max-w-sm aspect-[4/5] rounded-card overflow-hidden bg-lavender-200 flex items-center justify-center"
          role="img"
          aria-label="A young student proudly holding a drawing — placeholder for testimonial photo"
        >
          <div class="text-center p-8">
            <svg class="mx-auto mb-3 text-lavender-400" width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/>
            </svg>
            <p class="text-lavender-500 text-sm font-light">Photo coming soon</p>
            <p class="text-lavender-400 text-xs mt-1">public/images/testimonials/</p>
          </div>
        </div>

        <a
          href="https://www.google.com/maps/search/Vibrations+Violin+Studio+Denver"
          class="text-sm font-medium text-purplePrimary hover:text-purple-800 underline underline-offset-4 transition-colors"
          target="_blank"
          rel="noopener noreferrer"
        >
          Read More Reviews on Google &rarr;
        </a>
      </div>

    </div>
  </div>
</section>
