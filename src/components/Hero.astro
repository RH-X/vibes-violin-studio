---
---

<section
  class="relative w-full overflow-hidden"
  style="background: linear-gradient(135deg, #b4e7d0 0%, #ddd6fe 100%);"
  aria-labelledby="hero-heading"
>
  <!-- Decorative blobs -->
  <div class="pointer-events-none absolute -top-24 -left-24 w-96 h-96 rounded-full bg-mint-200 opacity-40 blur-3xl" aria-hidden="true"></div>
  <div class="pointer-events-none absolute -bottom-16 -right-16 w-80 h-80 rounded-full bg-lavender-300 opacity-30 blur-3xl" aria-hidden="true"></div>

  <div class="relative container-narrow section-pad text-center">
    <h1
      id="hero-heading"
      class="text-4xl sm:text-5xl lg:text-6xl font-light text-ink leading-tight max-w-3xl mx-auto"
    >
      Violin Lessons That Build<br class="hidden sm:inline" />
      <span class="text-purplePrimary">Musicianship, Confidence,<br class="hidden sm:inline" /> and Joy</span>
    </h1>

    <p class="mt-6 text-lg sm:text-xl text-ink/70 font-light leading-relaxed max-w-2xl mx-auto">
      with Rae McGee, M.M.
    </p>

    <p class="mt-4 text-base text-ink/60 font-light leading-relaxed max-w-[44rem] mx-auto">
      Private violin lessons in Denver, Colorado for children, teens, and adults, taught with Suzuki-based instruction. Students from beginners through advancing players are welcomed in my central Denver studio.
    </p>

    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="/contact" class="btn-secondary text-base px-8 py-3.5">
        Get Started
      </a>
      <a href="#approach" class="btn-primary text-base px-8 py-3.5">
        Learn More
      </a>
    </div>
  </div>
</section>
