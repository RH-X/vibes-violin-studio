<section class="bg-white section-pad" aria-labelledby="practice-pals-heading">
  <div class="container-narrow">
    <div class="grid grid-cols-1 lg:grid-cols-[5fr_3fr] gap-12 lg:gap-16 items-center">

      <!-- Left: Practice Pals demo image -->
      <div class="flex items-center justify-center">
        <img
          src="/images/practice-pals-demo.png"
          alt="Practice Pals app shown on a TV screen and tablet, featuring practice adventures and a friendly puppy buddy"
          class="w-full h-auto"
          width="2983"
          height="2105"
          loading="lazy"
        />
      </div>

      <!-- Right: copy -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-mint-500 mb-2">Feature</p>
        <h2
          id="practice-pals-heading"
          class="text-3xl sm:text-4xl font-light text-ink leading-tight"
        >
          Practice Pals
        </h2>
        <p class="mt-2 text-lg text-purplePrimary font-light">Make Violin Practice Fun and Positive</p>
        <p class="mt-4 text-base text-ink/60 font-light leading-relaxed">
          Practice Pals is our new violin practice app designed to support beginners and early players in building a healthy practice habit. Think of an at-home practice experience where learning exercises, games and learning check-ins meet the positive guidance of a practice buddy. Practice Pals is inspired by a curated collection of learning directions curated by the greats in music + pedagogy like Dr. Suzuki, Pablo Casals, and Carol Dweck to name a few. We are also highly powered by the experiences of our students and parents here at Vibrations Violin studio.
        </p>
        <div class="flex justify-end mt-8">
          <a href="/practice-pals" class="btn-primary inline-block">
            Learn More
          </a>
        </div>
      </div>

    </div>
  </div>
</section>
