---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'Private violin lessons in Denver, CO with Rae — Suzuki-trained instructor offering supportive, confidence-building lessons for all ages.',
  ogImage = '/images/og-default.jpg',
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteOrigin = Astro.site?.origin ?? 'https://vibesviolinstudio.com';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
   <meta name="google-site-verification" content="2_iVfArEU31IOv2yVDIHWL_iYSEuFDeLSOIRSVhsR2c" />
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? 'noindex,follow' : 'index,follow'} />

    <!-- SEO / GEO -->
    <meta name="geo.region" content="US-CO" />
    <meta name="geo.placename" content="Denver, Colorado" />

    <!-- OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>

    <!-- Preconnect for Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "LocalBusiness",
          "@id": `${siteOrigin}/#business`,
          "name": "Vibrations Violin Studio",
          "description": "Private violin lessons in Denver, Colorado. Suzuki-trained instruction for children, teens, and adults.",
          "url": siteOrigin,
          "telephone": "+1-720-253-0416",
          "email": "vibesviolinstudio@gmail.com",
          "address": {
            "@type": "PostalAddress",
            "addressLocality": "Denver",
            "addressRegion": "CO",
            "addressCountry": "US",
            "neighborhood": "Globeville"
          },
          "areaServed": [
            {
              "@type": "City",
              "name": "Denver",
              "containedInPlace": {
                "@type": "State",
                "name": "Colorado"
              }
            },
            ...["Wash Park", "Capitol Hill", "Cherry Creek", "Highlands", "Globeville", "RiNo", "LoHi", "City Park", "Sunnyside"].map(n => ({
              "@type": "Neighborhood",
              "name": n,
              "containedInPlace": {
                "@type": "City",
                "name": "Denver"
              }
            }))
          ],
          "founder": { "@id": `${siteOrigin}/#person` },
          "image": `${siteOrigin}/images/logos/vibrations-logo.jpg`,
          "sameAs": [
            "https://www.google.com/maps/place/Vibrations+Violin+Studio/@39.7637782,-105.184397,106113m/data=!3m2!1e3!4b1!4m6!3m5!1s0x876c7ff7ec8c4473:0x7211bc2c2fc447b4!8m2!3d39.7642444!4d-104.8547524!16s%2Fg%2F11ll2m56k5?entry=ttu",
            "https://www.linkedin.com/company/vibrations-violin-studio-denver/",
            "https://www.yelp.com/biz/vibrations-violin-studio-denver"
          ],
          "geo": {
            "@type": "GeoCoordinates",
            "latitude": 39.7642444,
            "longitude": -104.8547524
          },
          "hasMap": "https://www.google.com/maps/place/Vibrations+Violin+Studio/@39.7637782,-105.184397,106113m/data=!3m2!1e3!4b1!4m6!3m5!1s0x876c7ff7ec8c4473:0x7211bc2c2fc447b4!8m2!3d39.7642444!4d-104.8547524!16s%2Fg%2F11ll2m56k5?entry=ttu"
        },
        {
          "@type": "Person",
          "@id": `${siteOrigin}/#person`,
          "name": "Rae McGee",
          "jobTitle": "Music Instructor",
          "description": "Suzuki-trained violin instructor with 20+ years of experience teaching students of all ages in Denver, Colorado.",
          "worksFor": { "@id": `${siteOrigin}/#business` },
          "image": `${siteOrigin}/images/rae-mktg-site.png`,
          "sameAs": [
            "https://www.linkedin.com/company/vibrations-violin-studio-denver/"
          ]
        },
        {
          "@type": "Service",
          "@id": `${siteOrigin}/#service-in-person`,
          "name": "Private Violin Lessons — Denver",
          "description": "Private, Suzuki-informed violin lessons for beginners through advanced students of all ages. In-studio lessons in Globeville, Denver, CO.",
          "provider": { "@id": `${siteOrigin}/#business` },
          "serviceType": "Music Lessons",
          "areaServed": {
            "@type": "City",
            "name": "Denver",
            "containedInPlace": {
              "@type": "State",
              "name": "Colorado"
            }
          }
        },
        {
          "@type": "Service",
          "@id": `${siteOrigin}/#service-online`,
          "name": "Online Violin Lessons",
          "description": "Virtual private violin lessons available worldwide. Suzuki-informed instruction for all ages and levels.",
          "provider": { "@id": `${siteOrigin}/#business` },
          "serviceType": "Music Lessons",
          "availableChannel": {
            "@type": "ServiceChannel",
            "serviceType": "Online"
          }
        }
      ]
    })} />
  </head>
  <body>
    <!-- Skip to main content for accessibility -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-purplePrimary focus:text-white focus:rounded-lg"
    >
      Skip to main content
    </a>

    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
